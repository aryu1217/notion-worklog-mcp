{
  "name": "notion-worklog-mcp",
  "version": "0.1.0",
  "description": "An MCP server that turns Git activity into structured Notion worklog pages.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aryu1217/notion-worklog-mcp.git"
  },
  "keywords": [
    "mcp",
    "notion",
    "worklog",
    "git",
    "documentation"
  ],
  "files": [
    "dist",
    "templates",
    "README.md",
    "docs/README.ko.md",
    "LICENSE"
  ],
  "main": "./dist/core/index.js",
  "types": "./dist/core/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    }
  },
  "bin": {
    "notion-worklog-mcp": "./dist/mcp/index.js",
    "notion-worklog-mcp-doctor": "./dist/cli/doctor.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/mcp/index.ts",
    "doctor": "tsx src/cli/doctor.ts",
    "test": "node --import tsx --test ./tests/unit/*.test.ts ./tests/integration/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@notionhq/client": "^5.13.0",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=20"
  }
}
